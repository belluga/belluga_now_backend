<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         stopOnFailure="true"
         colors="true"
>
    <testsuites>
        <testsuite name="Feature-Initialization">
            <directory>tests/Feature/Initialization</directory>
        </testsuite>
        <testsuite name="Feature-Landlord">
            <directory>tests/Feature/Landlord</directory>
        </testsuite>
        <testsuite name="Feature-Accounts">
            <directory>tests/Feature/Accounts</directory>
        </testsuite>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Initialization">
            <file>tests/Api/default/Initialization/ApiDefaultInitializeTest.php</file>
        </testsuite>
        <testsuite name="Api-Default-Admin">
            <file>tests/Api/default/Admin/ApiDefaultAdminValidationTest.php</file>
            <file>tests/Api/default/Admin/ApiDefaultAdminRolesTest.php</file>
            <file>tests/Api/default/Admin/ApiDefaultAdminUserTest.php</file>
            <file>tests/Api/default/Admin/ApiDefaultAdminAuthTest.php</file>
            <file>tests/Api/default/Admin/ApiDefaultAdminProfileTest.php</file>
            <file>tests/Api/default/Admin/ApiDefaultAdminTenantTest.php</file>
            <file>tests/Api/default/Admin/ApiDefaultBrandingAdminTest.php</file>
        </testsuite>
        <testsuite name="Api-Default-Tenant">
            <directory>tests/Api/default/Tenants/Roles</directory>
            <directory>tests/Api/default/Tenants/Users</directory>
            <directory>tests/Api/default/Tenants/Account</directory>
            <directory>tests/Api/default/Tenants/Branding</directory>
            <directory>tests/Api/default/Tenants/Auth</directory>
        </testsuite>
        <testsuite name="Api-Default-Account">
            <directory>tests/Api/default/Accounts/Roles</directory>
            <directory>tests/Api/default/Accounts/Users</directory>
            <directory>tests/Api/default/Accounts/Auth</directory>
            <directory>tests/Api/default/Accounts/Profile</directory>
            <directory>tests/Api/default/Accounts/Validation</directory>
        </testsuite>
        <testsuite name="Api-Default-Middleware">
            <file>tests/Api/default/Admin/ApiDefaultAdminMiddlewareTest.php</file>
            <directory>tests/Api/default/Tenants/Middleware</directory>
            <directory>tests/Api/default/Accounts/Middleware</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_URL" value="http://nginx" />
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="DB_DATABASE" value="landlord_test" />
        <env name="DB_DATABASE_LANDLORD" value="landlord_test" />
        <env name="DB_DATABASE_TENANTS" value="tenants_test" />
    </php>
</phpunit>
